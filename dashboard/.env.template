# ============================================================
#  FDMS DASHBOARD - FRONTEND ENVIRONMENT TEMPLATE
#  Copy this file to ".env" inside the dashboard/ folder.
#  All values are also editable in src/config/company.js
#  (this env file overrides those defaults at build time).
# ============================================================

# --- Supabase (anon key is safe to expose in frontend) ---
VITE_SUPABASE_URL=https://<YOUR_PROJECT>.supabase.co
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# --- Company / taxpayer ---
VITE_COMPANY_NAME=<COMPANY LEGAL NAME>
VITE_COMPANY_SHORT_NAME=<Short Name>
VITE_COMPANY_ADDRESS=<Street, Suburb, City, Country>
VITE_COMPANY_PHONE=<Phone numbers>
VITE_COMPANY_EMAIL=<email@company.com>

# --- ZIMRA device ---
VITE_DEVICE_ID=<DEVICE_ID>
VITE_DEVICE_SERIAL=<SERIAL_NO>
VITE_TIN=<TIN>
VITE_VAT=<VAT_NUMBER>
VITE_DEVICE_MODEL=Server v1

# --- Tax config ---
VITE_VAT_RATE=15.5%
VITE_TAX_IDS=517 — Standard 15.5% · 2 — Zero rated · 1 — Exempt

# --- Environment: TEST or PRODUCTION ---
VITE_ENVIRONMENT=TEST
VITE_FDMS_ENDPOINT=fdmsapitest.zimra.co.zw
