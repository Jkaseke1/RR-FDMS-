# ============================================================
#  FDMS BRIDGE - BACKEND ENVIRONMENT TEMPLATE
#  Copy this file to ".env" and fill in the values for the
#  new client. Do NOT commit the real .env file.
# ============================================================

# --- Environment: test or production ---
NODE_ENV=test

# --- FDMS API ---
# TEST:       https://fdmsapitest.zimra.co.zw
# PRODUCTION: https://fdmsapi.zimra.co.zw
FDMS_BASE_URL=https://fdmsapitest.zimra.co.zw
FDMS_DEVICE_ID=<DEVICE_ID_FROM_ZIMRA>
FDMS_ACTIVATION_KEY=<8_DIGIT_ACTIVATION_KEY>
FDMS_DEVICE_SERIAL_NO=<DEVICE_SERIAL_NO>
FDMS_DEVICE_MODEL_NAME=Server
FDMS_DEVICE_MODEL_VERSION=v1

# --- Certificates (generated during device registration) ---
FDMS_CERT_PATH=./certs/device.cert.pem
FDMS_KEY_PATH=./certs/device.key.pem
FDMS_CA_PATH=./certs/fdms-root-ca.pem

# --- Supabase (create a new project per client or reuse) ---
SUPABASE_URL=https://<YOUR_PROJECT>.supabase.co
SUPABASE_SERVICE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>

# --- Customer / taxpayer ---
CUSTOMER_TIN=<TIN>
CUSTOMER_VAT=<VAT_NUMBER>
CUSTOMER_NAME=<COMPANY LEGAL NAME>

# --- Scheduling (set after getConfig response) ---
PING_INTERVAL_MINUTES=5
CONFIG_REFRESH_HOURS=24
CERT_RENEWAL_DAYS_BEFORE=30
