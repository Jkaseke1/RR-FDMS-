# ZIMRA FDMS Bridge - Production Configuration
# Copy this to .env and update with your production values

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# ZIMRA FDMS API
# ============================================
# Production API URL (use test URL for testing)
FDMS_URL=https://fdmsapi.zimra.co.zw
# FDMS_URL=https://fdmsapitest.zimra.co.zw

# Device Configuration
DEVICE_SERIAL=RapidR-1
DEVICE_ID=35224

# ============================================
# CERTIFICATES
# ============================================
# Path to your ZIMRA certificate (.p12 file)
CERT_PATH=./certs/RapidRoots.p12
CERT_PASSWORD=your_certificate_password_here

# ============================================
# FILE DIRECTORIES
# ============================================
# Where Sage prints PDFs (incoming)
UNSIGNED_DIR=C:/FDMS/unsigned

# Where fiscalized PDFs are saved
SIGNED_DIR=C:/FDMS/signed

# Where failed PDFs are moved
FAILED_DIR=C:/FDMS/failed

# Where logs are written
LOGS_DIR=C:/FDMS/logs

# ============================================
# SUPABASE (Optional - for cloud sync)
# ============================================
# Leave empty if not using Supabase
SUPABASE_URL=
SUPABASE_KEY=

# ============================================
# COMPANY INFORMATION
# ============================================
COMPANY_NAME=Rapid Roots Investments (Pvt) Ltd
COMPANY_TIN=2002054676
COMPANY_VAT=220401569

# ============================================
# PROCESSING OPTIONS
# ============================================
# How often to check for new PDFs (milliseconds)
POLL_INTERVAL=5000

# Maximum retries for failed fiscalizations
MAX_RETRIES=3

# Enable debug logging (true/false)
DEBUG=false

# ============================================
# FISCAL DAY MANAGEMENT
# ============================================
# Auto-open fiscal day if closed (true/false)
AUTO_OPEN_FISCAL_DAY=true

# Maximum fiscal day duration (hours)
MAX_FISCAL_DAY_HOURS=24

# ============================================
# NOTIFICATIONS (Optional)
# ============================================
# Email notifications for errors
NOTIFICATION_EMAIL=

# Slack webhook for alerts
SLACK_WEBHOOK_URL=
